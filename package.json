{
  "name": "rkyv-js",
  "version": "0.1.0",
  "description": "An unofficial library for rkyv (Rust zero-copy serialization framework)",
  "license": "MIT",
  "homepage": "https://github.com/cometkim/rkyv-js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cometkim/rkyv-js.git"
  },
  "author": {
    "name": "Hyeseong Kim",
    "email": "hey@hyeseong.kim"
  },
  "keywords": [
    "rkyv",
    "rust",
    "serialization",
    "deserialization",
    "zero-copy",
    "binary",
    "codec",
    "encoding",
    "decoding"
  ],
  "workspaces": [
    ".",
    "rkyv-example",
    "rkyv-js-codegen"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./core": "./src/core.ts",
    "./primitives": "./src/primitives.ts",
    "./lib/uuid": "./src/lib/uuid.ts",
    "./lib/bytes": "./src/lib/bytes.ts",
    "./lib/btreemap": "./src/lib/btreemap.ts",
    "./lib/hashmap": "./src/lib/hashmap.ts",
    "./lib/indexmap": "./src/lib/indexmap.ts"
  },
  "imports": {
    "#src/*": "./src/*",
    "#conformance/*": "./conformance/*"
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": "./dist/index.js",
      "./core": "./dist/core.js",
      "./primitives": "./dist/primitives.js",
      "./lib/uuid": "./dist/lib/uuid.js",
      "./lib/bytes": "./dist/lib/bytes.js",
      "./lib/btreemap": "./dist/lib/btreemap.js",
      "./lib/hashmap": "./dist/lib/hashmap.js",
      "./lib/indexmap": "./dist/lib/indexmap.js",
      "./package.json": "./package.json"
    }
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "test": "node --test",
    "check": "tsc --noEmit && tsc -p tsconfig.src.json --noEmit",
    "build": "node scripts/build.mjs",
    "prepack": "yarn build",
    "conformance:gen": "node scripts/conformance.mjs generate",
    "conformance:verify": "node scripts/conformance.mjs verify",
    "bench:comparison": "node --expose-gc benchmark/comparison.ts",
    "bench:primitives": "node --expose-gc benchmark/primitives.ts",
    "bench:encode": "node --expose-gc benchmark/encode.ts",
    "bench:decode": "node --expose-gc benchmark/decode.ts"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@codspeed/tinybench-plugin": "^5.7.1",
    "@mitata/counters": "^0.0.8",
    "@types/node": "^22.0.0",
    "amaro": "^1.1.10",
    "capnp-es": "^0.0.14",
    "cbor-x": "^1.6.4",
    "es-module-lexer": "^2.3.0",
    "mitata": "^1.0.34",
    "oxc-transform": "^0.139.0",
    "protobufjs": "^8.7.0",
    "tinybench": "^5.1.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "yarn@4.17.1"
}
